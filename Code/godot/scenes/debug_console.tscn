[connection signal="pressed" from="RootMargin/Root/Toolbar/RefreshButton" to="." method="_on_refresh_pressed"]
[connection signal="pressed" from="RootMargin/Root/Toolbar/ResetButton" to="." method="_on_reset_pressed"]
